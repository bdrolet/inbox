# Microsoft Graph delegated scopes. Outbound mail (drafts/send, incl. aliases,
# groups, shared mailboxes) requires Mail.ReadWrite, Mail.Send and their .Shared
# variants. After changing scopes you must re-consent and re-seed the MSAL token
# cache (scripts/seed_token_cache.py) — silent refresh won't pick up new scopes.
SCOPES=https://graph.microsoft.com/Mail.Read https://graph.microsoft.com/Mail.ReadWrite https://graph.microsoft.com/Mail.ReadWrite.Shared https://graph.microsoft.com/Mail.Send https://graph.microsoft.com/Mail.Send.Shared https://graph.microsoft.com/User.Read https://graph.microsoft.com/Calendars.ReadWrite

# Azure AD app registration (Graph API auth)
CLIENT_ID=
CLIENT_SECRET=
TENANT_ID=

# Cloud SQL / Postgres. Locally, set POSTGRES_HOST/PORT instead of
# CLOUD_SQL_CONNECTION_NAME for a direct psycopg connection.
CLOUD_SQL_CONNECTION_NAME=bens-project-462804:us-central1:inbox
POSTGRES_USER=inbox
POSTGRES_DB=app
POSTGRES_PASSWORD=

# Anthropic API (classifier)
ANTHROPIC_API_KEY=

# Grafana Cloud (OTel metrics/traces)
GRAFANA_OTLP_ENDPOINT=https://otlp-gateway-prod-us-west-0.grafana.net/otlp
GRAFANA_OTLP_TOKEN=
GRAFANA_PROM_URL=
GRAFANA_PROM_INSTANCE_ID=
GRAFANA_PROM_TOKEN=

# Asana (task creation)
ASANA_API_KEY=
ASANA_PROJECT_ID=

# Webhook / label action callbacks
WEBHOOK_URL=https://inbox-webhook-aizbgjlava-uc.a.run.app
WEBHOOK_LABEL_TOKEN=

# Hugging Face (bge embedding model download)
HF_TOKEN=

# HubSpot (optional — pipeline skips HubSpot logging if unset)
HUBSPOT_TOKEN=
OWN_EMAIL=ben@drolet.cloud

# Google Calendar OAuth2
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# ntfy notifications
NTFY_BASE_URL=https://ntfy.drolet.ai
NTFY_TOPIC=inbox
NTFY_TOKEN=

# inbox-api bearer token (set in Secret Manager in prod)
SEARCH_TOKEN=
