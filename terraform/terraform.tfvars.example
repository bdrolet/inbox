# Copy to terraform.tfvars (gitignored) and fill in real values.
# MSAL cache: run scripts/seed_token_cache.py locally after device login, paste JSON string.

client_id        = "azure-app-client-id"
client_secret    = "azure-app-client-secret"
tenant_id        = "azure-tenant-id"
openai_api_key   = "sk-..."
msal_token_cache = "{\"Account\":{},\"AccessToken\":{},\"RefreshToken\":{},\"IdToken\":{},\"AppMetadata\":{}}"

# Grafana Cloud OTLP — find in Grafana Cloud > My Account > OTLP endpoint
# Token: python3 -c "import base64; print(base64.b64encode(b'<instance_id>:<api_key>').decode())"
grafana_otlp_endpoint = "https://otlp-gateway-prod-<region>.grafana.net/otlp"
grafana_otlp_token    = "base64(instance_id:api_key)"

# HubSpot — from Settings → Legacy Apps → your private app → Access Token
hubspot_token = "pat-na2-..."

# Google Calendar OAuth2 — from GCP Console → APIs & Services → Credentials (Desktop app type)
# Run scripts/get_google_calendar_token.py locally to generate the refresh token
google_calendar_client_id       = ""
google_calendar_client_secret   = ""
google_calendar_refresh_token   = ""
